GEMINI_API_KEY=your_key_here
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
FLASK_SECRET_KEY=generate_a_random_32_byte_string
FLASK_ENV=production

# MQTT — ESP32 hardware RFID integration (HiveMQ Cloud)
MQTT_HOST=your-cluster.s2.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=rc_device_esp32
MQTT_PASS=your-mqtt-password
MQTT_TOPIC=resilientchain/rfid/scan
